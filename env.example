# ── Database (Supabase) ──────────────────────────────────────
# Connection pooling — used by the app at runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma migrations only
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# ── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-change-this"

# Your production URL (no trailing slash)
NEXTAUTH_URL="https://your-domain.com"

# ── Supabase (for Realtime) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ── Email (optional) ─────────────────────────────────────────
# Get free key at resend.com (3,000 emails/month free)
RESEND_API_KEY="re_..."
FROM_EMAIL="Aethr <notifications@yourdomain.com>"
