generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  avatarEmoji   String   @default("⚗️")
  bio           String?
  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  personas         Persona[]
  reputation       Reputation?
  presence         Presence?
  signals          Signal[]
  transmissions    Transmission[]
  roomMembers      RoomMember[]
  factionMembers   FactionMember[]
  tipsGiven        Tip[]             @relation("TipsGiven")
  tipsReceived     Tip[]             @relation("TipsReceived")
  debatesCreated   Debate[]          @relation("DebateCreator")
  debateVotes      DebateVote[]
  debateArguments  DebateArgument[]
  notifications    Notification[]
  discoveries      Discovery[]
  messagesSent     Message[]         @relation("MessagesSent")
  messagesReceived Message[]         @relation("MessagesReceived")
  mysteryExplorers MysteryExplorer[]
  mysteryAttempts  MysteryAttempt[]
  journalEntries   JournalEntry[]
  repTradesGiven   RepTrade[]        @relation("RepTradesGiven")
  repTradesReceived RepTrade[]       @relation("RepTradesReceived")
  signalReactions  SignalReaction[]
  following        Follow[]          @relation("Following")
  followers        Follow[]          @relation("Followers")

  @@map("users")
}

model Persona {
  id         String   @id @default(cuid())
  userId     String
  name       String
  type       String
  worldScope String[]
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signals Signal[]

  @@map("personas")
}

model Reputation {
  id         String   @id @default(cuid())
  userId     String   @unique
  wisdom     Int      @default(0)
  creativity Int      @default(0)
  discovery  Int      @default(0)
  trust      Int      @default(0)
  debate     Int      @default(0)
  legacy     Int      @default(0)
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reputations")
}

model Presence {
  id        String   @id @default(cuid())
  userId    String   @unique
  state     String   @default("open")
  worldId   String?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("presences")
}

model MemoryRoom {
  id          String   @id @default(cuid())
  name        String
  description String?
  worldId     String   @default("commons")
  color       String   @default("#a89bff")
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members RoomMember[]
  signals Signal[]

  @@map("memory_rooms")
}

model RoomMember {
  id       String     @id @default(cuid())
  userId   String
  roomId   String
  joinedAt DateTime   @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  room MemoryRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@map("room_members")
}

model Signal {
  id        String   @id @default(cuid())
  authorId  String
  personaId String?
  roomId    String?
  parentId  String?
  content   String
  worldId   String   @default("commons")
  mood      String?
  mediaUrl  String?
  createdAt DateTime @default(now())

  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  persona   Persona?        @relation(fields: [personaId], references: [id])
  room      MemoryRoom?     @relation(fields: [roomId], references: [id])
  parent    Signal?         @relation("SignalReplies", fields: [parentId], references: [id])
  replies   Signal[]        @relation("SignalReplies")
  reactions SignalReaction[]

  @@map("signals")
}

model SignalReaction {
  id        String   @id @default(cuid())
  signalId  String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)

  @@unique([signalId, userId, emoji])
  @@map("signal_reactions")
}

model Transmission {
  id          String   @id @default(cuid())
  creatorId   String
  title       String
  type        String
  worldId     String   @default("forge")
  isLive      Boolean  @default(false)
  viewers     Int      @default(0)
  mediaUrl    String?
  description String?
  createdAt   DateTime @default(now())

  creator User  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  tips    Tip[]

  @@map("transmissions")
}

model Tip {
  id             String        @id @default(cuid())
  fromUserId     String
  toUserId       String
  transmissionId String?
  amount         Int           @default(1)
  context        String
  createdAt      DateTime      @default(now())

  fromUser     User          @relation("TipsGiven",    fields: [fromUserId],     references: [id])
  toUser       User          @relation("TipsReceived", fields: [toUserId],       references: [id])
  transmission Transmission? @relation(fields: [transmissionId], references: [id])

  @@map("tips")
}

model Faction {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#a89bff")
  territory   String?
  createdAt   DateTime @default(now())

  members FactionMember[]

  @@map("factions")
}

model FactionMember {
  id        String   @id @default(cuid())
  userId    String
  factionId String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)
  faction Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)

  @@unique([userId, factionId])
  @@map("faction_members")
}

model Debate {
  id          String    @id @default(cuid())
  creatorId   String
  title       String
  description String?
  status      String    @default("open")
  endsAt      DateTime?
  createdAt   DateTime  @default(now())

  creator   User             @relation("DebateCreator", fields: [creatorId], references: [id])
  arguments DebateArgument[]
  votes     DebateVote[]

  @@map("debates")
}

model DebateArgument {
  id        String   @id @default(cuid())
  debateId  String
  authorId  String
  side      String
  content   String
  createdAt DateTime @default(now())

  debate Debate @relation(fields: [debateId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@map("debate_arguments")
}

model DebateVote {
  id       String @id @default(cuid())
  debateId String
  userId   String
  side     String

  debate Debate @relation(fields: [debateId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId],   references: [id])

  @@unique([debateId, userId])
  @@map("debate_votes")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Discovery {
  id        String   @id @default(cuid())
  authorId  String
  title     String
  content   String
  worldId   String   @default("deep")
  ripples   Int      @default(0)
  tags      String[]
  createdAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("discoveries")
}

model Message {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  fromUser User @relation("MessagesSent",     fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("MessagesReceived", fields: [toUserId],   references: [id], onDelete: Cascade)

  @@map("messages")
}

model Mystery {
  id          String    @id @default(cuid())
  title       String
  description String
  clues       String[]
  answer      String
  status      String    @default("active")
  solvedBy    String?
  solvedAt    DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  explorers MysteryExplorer[]
  attempts  MysteryAttempt[]

  @@map("mysteries")
}

model MysteryExplorer {
  id        String   @id @default(cuid())
  mysteryId String
  userId    String
  joinedAt  DateTime @default(now())

  mystery Mystery @relation(fields: [mysteryId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([mysteryId, userId])
  @@map("mystery_explorers")
}

model MysteryAttempt {
  id        String   @id @default(cuid())
  mysteryId String
  userId    String
  answer    String
  correct   Boolean
  createdAt DateTime @default(now())

  mystery Mystery @relation(fields: [mysteryId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@map("mystery_attempts")
}

model GalaxyEvent {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String
  worldId     String   @default("commons")
  actorId     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@map("galaxy_events")
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  content   String
  mood      String?
  worldId   String   @default("sanctum")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("journal_entries")
}

model Monument {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  worldId     String
  actorId     String?
  actorName   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@map("monuments")
}

model RepTrade {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  dimension   String
  amount      Int
  reason      String
  createdAt   DateTime @default(now())

  fromUser User @relation("RepTradesGiven",    fields: [fromUserId], references: [id])
  toUser   User @relation("RepTradesReceived", fields: [toUserId],   references: [id])

  @@map("rep_trades")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}
